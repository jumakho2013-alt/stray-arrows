# Copy this file to `keystore.properties` (without `.example`) and fill in the
# real values. The actual file is gitignored — passwords MUST NOT be committed.
#
# storeFile path is relative to android/app/ (where build.gradle lives), so
# `../../foo.keystore` means `<repo>/foo.keystore`.
storeFile=../../arrow-escape.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=YOUR_KEY_ALIAS
keyPassword=YOUR_KEY_PASSWORD
